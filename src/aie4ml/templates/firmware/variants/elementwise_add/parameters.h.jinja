{% set P = L.op_impl.parameters %}
struct {{L.struct_name}} {
  using lhs_t = {{P.precision.lhs.c_type}};
  using rhs_t = {{P.precision.rhs.c_type}};
  using result_t = {{P.precision.output.c_type}};
  using acc_scalar_t = {{ P.accumulator_tag }};
  static constexpr int CAS_NUM = {{P.parallelism.cas_num}};
  static constexpr int CAS_LENGTH = {{P.parallelism.cas_length}};
  static constexpr int VEC_SIZE = {{P.vec_size}};
  static constexpr int TILE_ELEMENTS = {{P.tile_elements}};
  static constexpr int SHIFT = {{P.shift}};
  static constexpr const char* ROUNDING_TOKEN = "{{ P.rounding_mode }}";
  static constexpr const char* SATURATION_TOKEN = "saturate";
#if __cplusplus >= 202002L
  static constexpr auto ROUNDING   = aie::rounding_mode::{{ P.rounding_mode }};
  static constexpr auto SATURATION = aie::saturation_mode::saturate;
#endif
